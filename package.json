{
	"name": "eslint-plugin-format-lua",
	"version": "1.0.0",
	"description": "An ESLint plugin for formatting Lua code using Stylua.",
	"keywords": [
		"eslint",
		"eslint-plugin",
		"formatters",
		"lua",
		"luau"
	],
	"homepage": "https://github.com/christopher-buss/eslint-plugin-format-lua",
	"bugs": {
		"url": "https://github.com/christopher-buss/eslint-plugin-format-lua/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christopher-buss/eslint-plugin-format-lua.git"
	},
	"license": "MIT",
	"author": {
		"email": "christopher.buss@pm.me",
		"name": "Christopher Buss",
		"url": "https://github.com/christopher-buss"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.mts",
	"files": [
		"dist",
		"dts"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "nr build && eslint .",
		"prepare": "simple-git-hooks ./simple-git-hooks.ts",
		"prepublishOnly": "nr build",
		"release": "bumpp",
		"start": "esno src/index.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@johnnymorganz/stylua": "^2.5.2",
		"eslint-formatting-reporter": "^0.0.0",
		"eslint-parser-plain": "^0.1.1"
	},
	"devDependencies": {
		"@antfu/ni": "^30.1.0",
		"@isentinel/eslint-config": "5.2.0",
		"@isentinel/tsconfig": "^1.2.0",
		"@types/node": "^22.16.0",
		"bumpp": "^11.1.0",
		"bundle-require": "^5.1.0",
		"eslint": "^9.39.4",
		"eslint-plugin-erasable-syntax-only": "^0.4.1",
		"eslint-plugin-n": "^18.1.0",
		"esno": "^4.8.0",
		"jiti": "^2.7.0",
		"lint-staged": "^17.0.7",
		"simple-git-hooks": "^2.13.1",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"eslint": "^9.38.0 || ^10.0.0"
	},
	"packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
	"engines": {
		"node": ">=22.16.0"
	}
}
